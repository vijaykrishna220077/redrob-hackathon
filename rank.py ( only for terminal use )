# ─────────────────────────────────────────────
# HELPER: days since a date string
# ─────────────────────────────────────────────
def days_since(date_str):
    if not date_str:
        return 9999
    try:
        d = datetime.strptime(date_str, "%Y-%m-%d").date()
        return (REFERENCE_DATE - d).days
    except Exception:
        return 9999


